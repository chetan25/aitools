{
  "name": "@aitools/guard",
  "version": "0.1.0",
  "description": "AST-level prompt injection detection for JavaScript/TypeScript",
  "license": "MIT",
  "author": "AITools Contributors",
  "homepage": "https://github.com/aitoolsmonorepo/aitools",
  "repository": {
    "type": "git",
    "url": "https://github.com/aitoolsmonorepo/aitools.git",
    "directory": "packages/@aitools/guard"
  },
  "bugs": {
    "url": "https://github.com/aitoolsmonorepo/aitools/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "@aitools/guard": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./eslint-plugin": {
      "types": "./dist/eslint-plugin.d.ts",
      "default": "./dist/eslint-plugin.js"
    },
    "./swc-plugin": "./swc-plugin.wasm"
  },
  "files": [
    "dist",
    "swc-plugin.wasm",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "prompt-injection",
    "security",
    "ai-safety",
    "eslint",
    "swc",
    "ast",
    "static-analysis"
  ],
  "scripts": {
    "build": "tsc && npm run build:wasm",
    "build:wasm": "echo 'SWC plugin build would occur here (requires Rust)'",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@babel/parser": "^7.22.0",
    "@types/estree": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.40.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.0"
  },
  "dependencies": {},
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    }
  }
}
