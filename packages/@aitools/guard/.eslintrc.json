{
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": ["@aitools/guard"],
  "extends": ["plugin:@aitools/guard/recommended"],
  "rules": {
    "@aitools/guard/unsafe-prompt": [
      "error",
      {
        "allowedSDKs": ["anthropic", "openai", "vercelAI"],
        "allowSafePattern": "aiGuard.safe"
      }
    ]
  }
}
