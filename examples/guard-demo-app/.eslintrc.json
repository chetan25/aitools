{
  "env": {
    "node": true,
    "es2021": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "plugins": [
    "@aitools/guard"
  ],
  "rules": {
    "@aitools/guard/unsafe-prompt": [
      "error",
      {
        "allowedSDKs": ["anthropic", "openai", "vercelAI"],
        "allowSafePattern": "aiGuard.safe"
      }
    ]
  }
}
